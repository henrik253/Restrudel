# Restrudel backend configuration (copy to .env — values here are the defaults)

# Server
PORT=8787
LOG_LEVEL=info

# Transcription adapter: mock | local | runpod
#   mock   — instant synthetic events, no dependencies (UI development)
#   local  — runs scripts/yourmt3_transcribe.py on CPU (needs .venv + models/)
#   runpod — RunPod Serverless GPU worker (Phase A1, not wired yet)
TRANSCRIBER=mock
# Artificial delay for the mock adapter, to exercise the progress UI
MOCK_DELAY_MS=0

# LLM (MIDI/events -> Strudel code)
#   provider auto: Anthropic SDK when ANTHROPIC_API_KEY is set, else `claude -p`
#   provider fake: canned code, no network (hermetic tests)
LLM_PROVIDER=auto
LLM_MODEL=claude-haiku-4-5
#ANTHROPIC_API_KEY=

# Paths (defaults derived from the repo layout — override only if needed)
#REPO_ROOT=
#DATA_GEN_DIR=   # must contain strudel_eval.mjs with node_modules installed
#PYTHON_BIN=     # default: <REPO_ROOT>/.venv/bin/python

# RunPod (only for TRANSCRIBER=runpod)
#RUNPOD_API_KEY=
#RUNPOD_ENDPOINT_ID=
